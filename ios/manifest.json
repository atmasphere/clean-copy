{
  "manifest_version": 3,
  "name": "Clean Copy",
  "version": "1.2.0",
  "description": "Extract clean article text and copy as Markdown or plain text",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://archive.today/*",
    "*://archive.ph/*",
    "*://archive.is/*",
    "*://archive.li/*",
    "*://archive.vn/*",
    "*://archive.fo/*",
    "*://archive.md/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "lib/turndown.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
